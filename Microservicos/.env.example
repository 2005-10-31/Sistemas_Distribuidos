# Copie este ficheiro para .env e preencha com  valores reais.
# O .env Não deve ser comitado (está no .gitignore).
JWT_SECRET=coloque_aqui_uma_chave_secreta
JWT_EXPIRATION=1h
ADMIN_USERS=[{"id":1,"username":"admin","password":"COLOQUE_AQUI"}]
# Chave partilhado entre o gateway  e os serviços internos.
# Impede que os serviços (5001/5002/5003) sejam chamados diretamente sem passar pelo gateway.
INTERNAL_TOKEN=coloque_aqui_uma_chave_secreta_interna